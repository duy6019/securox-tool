{
  "name": "securox-tool",
  "version": "1.0.0",
  "bin": {
    "securox": "dist/index.js"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "build:bin": "bun build ./src/index.ts --compile --outfile dist/securox",
    "build:action": "bun build ./src/action.ts --outfile dist/action.js --target node",
    "start": "bun run ./src/index.ts",
    "test": "bun test tests/unit",
    "test:integration": "bun test tests/integration --timeout 60000",
    "test:all": "bun test tests/",
    "download:bins": "bun run scripts/download-binaries.ts"
  },
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/decompress": "^4.2.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@actions/cache": "^6.0.0",
    "@actions/core": "^3.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "decompress": "^4.2.1",
    "decompress-targz": "^4.1.1",
    "decompress-unzip": "^4.0.1",
    "execa": "^9.6.1",
    "js-yaml": "^4.1.1",
    "ora": "^9.3.0"
  }
}
